# =============================================================================
# FLORA VOICE AGENT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# LIVEKIT CLOUD CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from your LiveKit Cloud dashboard: https://cloud.livekit.io
# Go to Settings > Keys to find your API Key and Secret

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# -----------------------------------------------------------------------------
# DEEPGRAM - Speech-to-Text (STT)
# -----------------------------------------------------------------------------
# Sign up at: https://console.deepgram.com
# Create an API key with "Usage" permissions

DEEPGRAM_API_KEY=your_deepgram_api_key

# -----------------------------------------------------------------------------
# OPENAI - Language Model (LLM)
# -----------------------------------------------------------------------------
# Sign up at: https://platform.openai.com
# Create an API key at: https://platform.openai.com/api-keys

OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# ELEVENLABS - Text-to-Speech (TTS)
# -----------------------------------------------------------------------------
# Sign up at: https://elevenlabs.io
# Get your API key from: https://elevenlabs.io/settings/api-keys
# Find voice IDs at: https://elevenlabs.io/voices

ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional: Specify a different ElevenLabs voice
# Default is "Sarah" (EXAVITQu4vr4xnSDxMaL) - a warm, friendly female voice
# Browse voices at https://elevenlabs.io/voice-library to find alternatives
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# -----------------------------------------------------------------------------
# TWILIO - SIP Trunk for Phone Calls
# -----------------------------------------------------------------------------
# Sign up at: https://www.twilio.com
#
# Account SID and Auth Token:
#   Found on your Twilio Console dashboard: https://console.twilio.com
#
# To set up SIP Trunk:
#   1. Go to Elastic SIP Trunking > Trunks
#   2. Create a new trunk
#   3. Configure Origination URI with your LiveKit SIP endpoint
#   4. Buy a phone number and assign it to the trunk

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# -----------------------------------------------------------------------------
# AIRTABLE - Call Logging
# -----------------------------------------------------------------------------
# Sign up at: https://airtable.com
#
# To get your Personal Access Token (PAT):
#   1. Go to: https://airtable.com/create/tokens
#   2. Create a new token with these scopes:
#      - data.records:read
#      - data.records:write
#   3. Grant access to your base
#
# To find your Base ID:
#   1. Go to: https://airtable.com/api
#   2. Click on your base
#   3. The Base ID starts with "app" and is in the URL

AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# COST PROTECTION
# -----------------------------------------------------------------------------
# Maximum call duration in seconds before automatically disconnecting
# This prevents runaway costs from stuck or looping calls
# Default: 600 (10 minutes)

MAX_CALL_DURATION_SECONDS=600
